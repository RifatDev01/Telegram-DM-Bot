<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bot Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        .login-box {
            background: white;
            border-radius: 20px;
            padding: 40px;
            max-width: 400px;
            margin: 100px auto;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .history-section {
            display: none;
        }
        .history-section.active {
            display: block;
        }
        h1 { color: #333; margin-bottom: 10px; text-align: center; }
        .subtitle { color: #666; text-align: center; margin-bottom: 30px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 8px; color: #333; font-weight: 600; }
        input {
            width: 100%;
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 16px;
        }
        button {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
        }
        .error { color: red; margin-top: 10px; text-align: center; }
        .status-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .status-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .status-indicator {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #ff4444;
        }
        .status-indicator.online {
            background: #4CAF50;
        }
        .status-info {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }
        .info-item {
            flex: 1;
            min-width: 200px;
        }
        .info-label {
            color: #666;
            font-size: 14px;
            margin-bottom: 5px;
        }
        .info-value {
            color: #333;
            font-size: 24px;
            font-weight: 600;
        }
        .history-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .history-header {
            margin-bottom: 20px;
        }
        .history-item {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .history-item:last-child {
            border-bottom: none;
        }
        .message-info {
            flex: 1;
        }
        .sender {
            font-weight: 600;
            color: #667eea;
            margin-bottom: 5px;
        }
        .message {
            color: #333;
            margin-bottom: 5px;
        }
        .reply {
            color: #4CAF50;
            font-size: 14px;
        }
        .timestamp {
            color: #999;
            font-size: 12px;
            min-width: 150px;
            text-align: right;
        }
        .no-history {
            text-align: center;
            color: #999;
            padding: 30px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Bot Status Card (Public) -->
        <div class="status-card">
            <div class="status-header">
                <h2>📊 Bot Status</h2>
                <div class="status-indicator" id="statusIndicator"></div>
            </div>
            <div class="status-info">
                <div class="info-item">
                    <div class="info-label">স্ট্যাটাস</div>
                    <div class="info-value" id="statusText">Checking...</div>
                </div>
                <div class="info-item">
                    <div class="info-label">অনলাইন সময়</div>
                    <div class="info-value" id="onlineTime">0h 0m 0s</div>
                </div>
                <div class="info-item">
                    <div class="info-label">আপডেট</div>
                    <div class="info-value" id="lastUpdate">--:--:--</div>
                </div>
            </div>
        </div>

        <!-- Login for History -->
        <div class="login-box" id="loginPage">
            <h1>🔐 মেসেজ হিস্ট্রি দেখুন</h1>
            <p class="subtitle">পাসওয়ার্ড দিয়ে লগইন করুন</p>
            <div class="form-group">
                <label>পাসওয়ার্ড</label>
                <input type="password" id="password" placeholder="পাসওয়ার্ড দিন">
            </div>
            <button onclick="login()">লগইন করুন</button>
            <div class="error" id="loginError"></div>
        </div>

        <!-- Message History (Protected) -->
        <div class="history-section" id="historySection">
            <div class="history-card">
                <div class="history-header">
                    <h2>📜 মেসেজ হিস্ট্রি (শেষ ২ দিন)</h2>
                </div>
                <div id="historyList"></div>
            </div>
        </div>
    </div>

    <script>
        let isAuthenticated = false;

        // Start status updates immediately (no login required)
        startStatusUpdates();

        function login() {
            const password = document.getElementById('password').value;
            
            fetch('/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ password })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    isAuthenticated = true;
                    document.getElementById('loginPage').style.display = 'none';
                    document.getElementById('historySection').classList.add('active');
                    loadHistory();
                } else {
                    document.getElementById('loginError').textContent = 'ভুল পাসওয়ার্ড!';
                }
            });
        }

        function updateStatus() {
            fetch('/api/status')
            .then(res => res.json())
            .then(data => {
                const indicator = document.getElementById('statusIndicator');
                const statusText = document.getElementById('statusText');
                const onlineTime = document.getElementById('onlineTime');
                const lastUpdate = document.getElementById('lastUpdate');

                if (data.running) {
                    indicator.classList.add('online');
                    statusText.textContent = 'Online';
                    statusText.style.color = '#4CAF50';
                } else {
                    indicator.classList.remove('online');
                    statusText.textContent = 'Offline';
                    statusText.style.color = '#ff4444';
                }

                onlineTime.textContent = data.onlineTime;
                lastUpdate.textContent = new Date().toLocaleTimeString();
            });
        }

        function loadHistory() {
            fetch('/api/history?days=2')
            .then(res => res.json())
            .then(data => {
                const historyList = document.getElementById('historyList');
                
                if (data.history.length === 0) {
                    historyList.innerHTML = '<div class="no-history">কোনো মেসেজ হিস্ট্রি নেই</div>';
                    return;
                }

                historyList.innerHTML = data.history.map(item => `
                    <div class="history-item">
                        <div class="message-info">
                            <div class="sender">${item.sender.username || item.sender.firstName || 'Unknown'}</div>
                            <div class="message">মেসেজ: ${item.message}</div>
                            <div class="reply">রিপ্লাই: ${item.reply}</div>
                        </div>
                        <div class="timestamp">${new Date(item.timestamp).toLocaleString('bn-BD')}</div>
                    </div>
                `).join('');
            });
        }

        function startStatusUpdates() {
            updateStatus();
            setInterval(updateStatus, 5000); // Update every 5 seconds
        }

        // Enter key to login
        document.getElementById('password').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') login();
        });
    </script>
</body>
</html>
